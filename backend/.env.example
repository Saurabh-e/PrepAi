# Application Port
PORT=8080

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/ai_interview_platform
# For Production / Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/ai_interview_platform

# Security Configuration
JWT_SECRET=your-super-secret-key-minimum-256-bits-long-for-production-use

# Local Storage Uploads Settings
FILE_UPLOAD_DIR=uploads
FILE_BASE_URL=http://localhost:8080/uploads

# Groq API Configuration
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# CORS Allowed Origin Patterns (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://localhost:5173,https://*.vercel.app

# Cloudinary Storage Settings (Optional, falls back to local storage if keys are not set)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
